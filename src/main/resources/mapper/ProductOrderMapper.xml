<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.petshop.mapper.ProductOrderMapper">

    <!-- 结果映射：ProductOrder 带 Merchant -->
    <resultMap id="ProductOrderWithMerchantMap" type="com.petshop.entity.ProductOrder">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="userId" column="user_id"/>
        <result property="merchantId" column="merchant_id"/>
        <result property="totalPrice" column="total_price"/>
        <result property="freight" column="freight"/>
        <result property="status" column="status"/>
        <result property="payMethod" column="pay_method"/>
        <result property="remark" column="remark"/>
        <result property="shippingAddress" column="shipping_address"/>
        <result property="logisticsCompany" column="logistics_company"/>
        <result property="logisticsNumber" column="logistics_number"/>
        <result property="transactionId" column="transaction_id"/>
        <result property="paidAt" column="paid_at"/>
        <result property="shippedAt" column="shipped_at"/>
        <result property="completedAt" column="completed_at"/>
        <result property="cancelledAt" column="cancelled_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <association property="merchant" javaType="com.petshop.entity.Merchant">
            <id property="id" column="merchant_id"/>
            <result property="name" column="merchant_name"/>
            <result property="contactPerson" column="merchant_contact_person"/>
            <result property="phone" column="merchant_phone"/>
            <result property="email" column="merchant_email"/>
            <result property="address" column="merchant_address"/>
            <result property="logo" column="merchant_logo"/>
            <result property="status" column="merchant_status"/>
            <result property="createdAt" column="merchant_created_at"/>
            <result property="updatedAt" column="merchant_updated_at"/>
        </association>
    </resultMap>

    <!-- 根据ID查询订单，同时加载商家信息 -->
    <select id="selectByIdWithMerchant" resultMap="ProductOrderWithMerchantMap">
        SELECT
            po.*,
            m.id as merchant_id,
            m.name as merchant_name,
            m.contact_person as merchant_contact_person,
            m.phone as merchant_phone,
            m.email as merchant_email,
            m.address as merchant_address,
            m.logo as merchant_logo,
            m.status as merchant_status,
            m.created_at as merchant_created_at,
            m.updated_at as merchant_updated_at
        FROM product_order po
        LEFT JOIN merchant m ON po.merchant_id = m.id
        WHERE po.id = #{id}
    </select>

</mapper>
